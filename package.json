{
  "name": "responsibleapi",
  "type": "module",
  "scripts": {
    "check": "bun run check:fast",
    "check:fast": "bun run --parallel typecheck lint test",
    "check:full": "bun run --parallel --no-exit-on-error typecheck lint test",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint src",
    "lint:fix": "oxlint --fix src",
    "test": "bun test",
    "test-dont-use": "vitest run src/",
    "typecheck": "tsc"
  },
  "dependencies": {
    "@seriousme/openapi-schema-validator": "^2.8.0",
    "openapi3-ts": "^4.5.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "oxlint-tsgolint": "^0.18.1",
    "typescript": "^6.0.2",
    "vitest": "4.1.2"
  },
  "x-package-json-docs": "docs/package.jsonc"
}
